<turbo-frame id="truck_modal">
  <div class="fixed inset-0 z-50 flex items-center justify-center bg-gray-900/60 px-4 py-6" data-controller="modal" data-action="keyup@window->modal#maybeClose">
    <div class="absolute inset-0" data-action="click->modal#close"></div>

    <div class="relative z-10 w-full max-w-lg rounded-2xl bg-white p-6 shadow-xl">
      <div class="flex items-start justify-between">
        <div>
          <h2 class="text-xl font-semibold text-gray-900">Edit Truck</h2>
          <p class="text-sm text-gray-600">Update capacities or MPG.</p>
        </div>
        <button class="text-gray-400 hover:text-gray-700" data-action="click->modal#close">
          <span class="sr-only">Close</span>
          ✕
        </button>
      </div>

      <%= form_with model: @truck, url: truck_path(@truck), method: :patch, local: true, class: "mt-6 space-y-4" do |f| %>
        <% if @truck.errors.any? %>
          <div class="rounded-lg border border-red-200 bg-red-50 p-3 text-sm text-red-700">
            <%= @truck.errors.full_messages.to_sentence %>
          </div>
        <% end %>

        <div class="grid gap-3 md:grid-cols-2">
          <div>
            <%= f.label :name, class: "text-xs font-medium text-gray-600" %>
            <%= f.text_field :name, class: "mt-1 block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm" %>
          </div>
          <div>
            <%= f.label :number, class: "text-xs font-medium text-gray-600" %>
            <%= f.text_field :number, class: "mt-1 block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm" %>
          </div>
          <div>
            <%= f.label :clean_water_capacity_gal, "Clean water (gal)", class: "text-xs font-medium text-gray-600" %>
            <%= f.number_field :clean_water_capacity_gal, min: 0, class: "mt-1 block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm" %>
          </div>
          <div>
            <%= f.label :waste_capacity_gal, "Waste (gal)", class: "text-xs font-medium text-gray-600" %>
            <%= f.number_field :waste_capacity_gal, min: 0, class: "mt-1 block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm" %>
          </div>
          <div>
            <%= f.label :miles_per_gallon, "Miles per gallon", class: "text-xs font-medium text-gray-600" %>
            <%= f.number_field :miles_per_gallon, min: 0, step: "0.1", class: "mt-1 block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm" %>
          </div>
          <div>
            <%= f.label :preference_rank, "Preference rank", class: "text-xs font-medium text-gray-600" %>
            <%= f.number_field :preference_rank, min: 1, class: "mt-1 block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm" %>
          </div>
        </div>

        <div class="space-y-3 rounded-xl border border-gray-200 bg-gray-50 p-3">
          <p class="text-xs font-semibold uppercase tracking-wide text-gray-500">Operational thresholds (blank = default)</p>
          <div class="grid gap-3 md:grid-cols-2">
            <div>
              <%= f.label :waste_yellow_threshold_pct, "Waste Tank: Warning Level (%, default 65)", class: "text-xs font-medium text-gray-600" %>
              <%= f.number_field :waste_yellow_threshold_pct, min: 0, max: 100, placeholder: "65", class: "mt-1 block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm" %>
            </div>
            <div>
              <%= f.label :waste_red_threshold_pct, "Waste Tank: Priority Level (%, default 85)", class: "text-xs font-medium text-gray-600" %>
              <%= f.number_field :waste_red_threshold_pct, min: 0, max: 100, placeholder: "85", class: "mt-1 block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm" %>
            </div>
            <div>
              <%= f.label :waste_red_nearby_miles, "Waste Tank: Priority Radius (miles, default 5)", class: "text-xs font-medium text-gray-600" %>
              <%= f.number_field :waste_red_nearby_miles, min: 0, step: "0.1", placeholder: "5", class: "mt-1 block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm" %>
            </div>
            <div>
              <%= f.label :waste_early_dump_proximity_miles, "Waste Tank: Early Dump Threshold (miles, default 10)", class: "text-xs font-medium text-gray-600" %>
              <%= f.number_field :waste_early_dump_proximity_miles, min: 0, step: "0.1", placeholder: "10", class: "mt-1 block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm" %>
            </div>
            <div>
              <%= f.label :water_yellow_threshold_pct, "Clean Water: Warning Level (%, default 35)", class: "text-xs font-medium text-gray-600" %>
              <%= f.number_field :water_yellow_threshold_pct, min: 0, max: 100, placeholder: "35", class: "mt-1 block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm" %>
            </div>
            <div>
              <%= f.label :water_red_threshold_pct, "Clean Water: Priority Level (%, default 15)", class: "text-xs font-medium text-gray-600" %>
              <%= f.number_field :water_red_threshold_pct, min: 0, max: 100, placeholder: "15", class: "mt-1 block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm" %>
            </div>
            <div>
              <%= f.label :water_red_nearby_miles, "Clean Water: Priority Radius (miles, default 5)", class: "text-xs font-medium text-gray-600" %>
              <%= f.number_field :water_red_nearby_miles, min: 0, step: "0.1", placeholder: "5", class: "mt-1 block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm" %>
            </div>
            <div>
              <%= f.label :water_early_refill_proximity_miles, "Clean Water: Early Refill Threshold (miles, default 10)", class: "text-xs font-medium text-gray-600" %>
              <%= f.number_field :water_early_refill_proximity_miles, min: 0, step: "0.1", placeholder: "10", class: "mt-1 block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm" %>
            </div>
            <div>
              <%= f.label :water_min_reserve_gal, "Clean Water: Minimum Reserve (gal, default 10)", class: "text-xs font-medium text-gray-600" %>
              <%= f.number_field :water_min_reserve_gal, min: 0, placeholder: "10", class: "mt-1 block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm" %>
            </div>
          </div>
        </div>

        <div class="flex justify-end gap-3 pt-2">
          <button type="button" class="inline-flex items-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-gray-700 ring-1 ring-inset ring-gray-300 hover:bg-gray-50" data-action="click->modal#close">Cancel</button>
          <%= f.submit "Save truck", class: "inline-flex items-center rounded-lg bg-gray-900 px-4 py-2 text-sm font-semibold text-white hover:bg-gray-800" %>
        </div>
      <% end %>
    </div>
  </div>
</turbo-frame>
