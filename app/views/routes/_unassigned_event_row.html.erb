<% customer_or_site = event.order&.customer&.display_name.presence || event.dump_site&.name.presence || "Unassigned" %>
<% event_label = event.event_type_service? ? "Pump" : event.event_type.to_s.humanize %>
<% row_label = "#{event_label} · #{customer_or_site}" %>

<li class="flex items-center justify-between gap-2 py-1.5"
    draggable="true"
    data-service-event-id="<%= event.id %>"
    data-service-event-date="<%= event.scheduled_on %>"
    data-service-event-series-eligible="<%= (event.event_type_service? && event.order_id.present?).to_s %>"
    data-action="dragstart->routes-calendar#dragStart dragend->routes-calendar#dragEnd"
    role="button"
    tabindex="0"
    title="Drag to reschedule">
  <span class="inline-flex h-5 w-5 shrink-0 items-center justify-center rounded border border-gray-200 bg-white text-[10px] text-gray-500">::</span>
  <span class="block w-full truncate rounded px-1 py-0.5 text-xs text-gray-700 transition hover:bg-amber-50 cursor-grab active:cursor-grabbing"><%= row_label %></span>
</li>
