<% content_for :title, "Day Routes" %>

<div class="mx-auto max-w-5xl px-4 py-6" data-controller="day-route-assignment">
  <div class="rounded-2xl border border-gray-200 bg-white p-4 shadow-sm">
    <div class="flex flex-wrap items-center justify-between gap-3">
      <div>
        <p class="text-sm font-semibold text-gray-700">Route day plan</p>
        <p class="text-lg font-semibold text-gray-900"><%= l(@date, format: :long) %></p>
      </div>
      <div class="flex gap-2">
        <% if @date >= Date.current %>
          <%= button_to "Clear day routes",
                        clear_day_routes_path(date: @date.to_s, strategy: @calendar_strategy),
                        method: :post,
                        local: true,
                        form: { data: { turbo_confirm: "Clear all routes for this day and release events back to unassigned?" }, class: "inline-block" },
                        class: "rounded-lg border border-rose-200 bg-rose-50 px-3 py-2 text-sm font-semibold text-rose-700 hover:bg-rose-100" %>
        <% end %>
        <%= link_to "←",
                    day_routes_path(date: @date - 1.day, strategy: @calendar_strategy),
                    class: "rounded-lg border border-gray-200 bg-white px-3 py-2 text-sm font-semibold text-gray-700 hover:bg-gray-50",
                    aria: { label: "Previous day" } %>
        <%= link_to "→",
                    day_routes_path(date: @date + 1.day, strategy: @calendar_strategy),
                    class: "rounded-lg border border-gray-200 bg-white px-3 py-2 text-sm font-semibold text-gray-700 hover:bg-gray-50",
                    aria: { label: "Next day" } %>
        <%= link_to "← Back to calendar",
                    calendar_routes_path(
                      start: @date.beginning_of_week(:sunday),
                      strategy: @calendar_strategy
                    ),
                    class: "rounded-lg border border-gray-200 bg-white px-3 py-2 text-sm font-semibold text-gray-700 hover:bg-gray-50" %>
        <%= link_to "Tasks",
                    tasks_path(date: @date.to_s),
                    class: "rounded-lg border border-gray-200 bg-white px-3 py-2 text-sm font-semibold text-gray-700 hover:bg-gray-50" %>
      </div>
    </div>

    <div class="mt-6 grid gap-4 md:grid-cols-[2fr_1fr]">
      <section class="rounded-2xl border border-gray-100 bg-gray-50 p-4">
        <div class="flex items-center justify-between gap-3">
          <h2 class="text-sm font-semibold text-gray-900">Unassigned due events</h2>
          <% if @unassigned_events.any? %>
            <p class="text-xs text-gray-500">Drag an event onto a route to assign it.</p>
          <% end %>
        </div>
        <% if @unassigned_events.any? %>
          <ul class="mt-3 space-y-2">
            <% @unassigned_events.each do |event| %>
              <% label = if event.order
                           event.order.customer&.display_name
                         elsif event.dump_site
                           event.dump_site.name
                         end %>
              <li class="cursor-grab rounded-xl border border-amber-200 bg-amber-50 px-3 py-2 text-sm text-amber-900 active:cursor-grabbing"
                  draggable="true"
                  data-service-event-id="<%= event.id %>"
                  data-action="dragstart->day-route-assignment#dragStart dragend->day-route-assignment#dragEnd"
                  title="Drag onto a route to assign">
                <span class="font-semibold"><%= event.event_type.to_s.humanize %></span>
                <span class="text-gray-700">· <%= event.scheduled_on %></span>
                <% if label.present? %>
                  <%= " · #{label}" %>
                <% end %>
              </li>
            <% end %>
          </ul>
        <% else %>
          <p class="mt-2 text-sm text-gray-500">No unassigned due events.</p>
        <% end %>
      </section>

      <section class="rounded-2xl border border-gray-100 bg-gray-50 p-4">
        <h2 class="text-sm font-semibold text-gray-900">Routes for this day</h2>
        <% stops_by_route_id = @assigned_stops.group_by(&:route_id) %>
        <% if @routes_for_day.any? %>
          <div class="mt-3 space-y-4">
            <% @routes_for_day.each do |route| %>
              <% stops = stops_by_route_id[route.id] || [] %>
              <div class="rounded-2xl border border-gray-200 bg-white p-3 transition"
                   data-day-route-assignment-target="routeCard"
                   data-route-id="<%= route.id %>"
                   data-action="dragover->day-route-assignment#dragOver drop->day-route-assignment#drop dragleave->day-route-assignment#dragLeave">
                <h3 class="text-xs font-semibold uppercase tracking-wide text-gray-600">
                  <%= link_to RoutePresenter.new(route).display_name, route_path(route), class: "text-blue-700 underline" %>
                </h3>
                <% if stops.any? %>
                  <ul class="mt-2 space-y-2">
                    <% stops.each do |stop| %>
                      <% event = stop.service_event %>
                      <li class="rounded-xl border border-gray-200 bg-gray-50 px-3 py-2 text-sm">
                        <%= stop.position + 1 %>. <%= event&.event_type.to_s&.humanize %>
                        <% if event&.order %>
                          · <%= event.order.customer&.display_name %>
                        <% end %>
                      </li>
                    <% end %>
                  </ul>
                <% else %>
                  <p class="mt-2 rounded-xl border border-dashed border-gray-300 px-3 py-3 text-sm text-gray-500">
                    Drop an unassigned event here to add it to this route.
                  </p>
                <% end %>
              </div>
            <% end %>
          </div>
        <% else %>
          <p class="mt-2 text-sm text-gray-500">No routes for this date.</p>
        <% end %>
      </section>
    </div>
  </div>
</div>
