<% content_for :title, "Day Routes" %>

<div class="mx-auto max-w-5xl px-4 py-6">
  <div class="rounded-2xl border border-gray-200 bg-white p-4 shadow-sm">
    <div class="flex flex-wrap items-center justify-between gap-3">
      <div>
        <p class="text-sm font-semibold text-gray-700">Route day plan</p>
        <p class="text-lg font-semibold text-gray-900"><%= l(@date, format: :long) %></p>
      </div>
      <div class="flex gap-2">
        <%= link_to "←",
                    day_routes_path(date: @date - 1.day, run_id: @generation_run&.id, strategy: @calendar_strategy),
                    class: "rounded-lg border border-gray-200 bg-white px-3 py-2 text-sm font-semibold text-gray-700 hover:bg-gray-50",
                    aria: { label: "Previous day" } %>
        <%= link_to "→",
                    day_routes_path(date: @date + 1.day, run_id: @generation_run&.id, strategy: @calendar_strategy),
                    class: "rounded-lg border border-gray-200 bg-white px-3 py-2 text-sm font-semibold text-gray-700 hover:bg-gray-50",
                    aria: { label: "Next day" } %>
        <%= link_to "← Back to calendar",
                    calendar_routes_path(start: @date.beginning_of_week(:sunday), run_id: @generation_run&.id),
                    class: "rounded-lg border border-gray-200 bg-white px-3 py-2 text-sm font-semibold text-gray-700 hover:bg-gray-50" %>
        <%= link_to "Tasks",
                    tasks_path(date: @date.to_s),
                    class: "rounded-lg border border-gray-200 bg-white px-3 py-2 text-sm font-semibold text-gray-700 hover:bg-gray-50" %>
      </div>
    </div>

    <div class="mt-6 grid gap-4 md:grid-cols-[2fr_1fr]">
      <section class="rounded-2xl border border-gray-100 bg-gray-50 p-4">
        <h2 class="text-sm font-semibold text-gray-900">Unassigned due events</h2>
        <% if @unassigned_events.any? %>
          <ul class="mt-3 space-y-2">
            <% @unassigned_events.each do |event| %>
              <li class="rounded-xl border border-amber-200 bg-amber-50 px-3 py-2 text-sm text-amber-900">
                <span class="font-semibold"><%= event.event_type.to_s.humanize %></span>
                <span class="text-gray-700">· <%= event.scheduled_on %></span>
                <% if event.order %>
                  <%= " · #{event.order.customer&.display_name}" %>
                <% elsif event.dump_site %>
                  <%= " · #{event.dump_site.name}" %>
                <% end %>
              </li>
            <% end %>
          </ul>
        <% else %>
          <p class="mt-2 text-sm text-gray-500">No unassigned due events.</p>
        <% end %>
      </section>

      <section class="rounded-2xl border border-gray-100 bg-gray-50 p-4">
        <h2 class="text-sm font-semibold text-gray-900">Assigned in active run</h2>
        <% if @assigned_stops.any? %>
          <ul class="mt-3 space-y-2">
            <% @assigned_stops.each do |stop| %>
              <% event = stop.service_event %>
              <li class="rounded-xl border border-gray-200 bg-white px-3 py-2 text-sm">
                <%= stop.position + 1 %>. <%= event&.event_type.to_s&.humanize %>
                <% if event&.route_id %>
                  via <%= link_to "Route ##{event.route_id}", route_path(event.route), class: "text-blue-700 underline" %>
                <% end %>
                <% if event&.order %>
                  · <%= event.order.customer&.display_name %>
                <% end %>
              </li>
            <% end %>
          </ul>
        <% else %>
          <p class="mt-2 text-sm text-gray-500">No assigned events for this active run.</p>
        <% end %>
      </section>
    </div>

    <section class="mt-6 rounded-2xl border border-gray-100 bg-white p-4">
      <h2 class="text-sm font-semibold text-gray-900">Routes</h2>
      <% if @generation_run.present? && @generation_run.routes.where(route_date: @date).any? %>
        <ul class="mt-3 space-y-2">
          <% @generation_run.routes.where(route_date: @date).each do |route| %>
            <li>
              <%= link_to "Route ##{route.id} (#{route.truck&.name || 'Unassigned truck'})",
                          route_path(route),
                          class: "text-sm text-blue-700 underline" %>
            </li>
          <% end %>
        </ul>
      <% else %>
        <p class="mt-2 text-sm text-gray-500">No routes for this date in the active planning run.</p>
      <% end %>
    </section>
  </div>
</div>
